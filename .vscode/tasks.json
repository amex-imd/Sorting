{
    "version": "2.0.0",
    "tasks": [
        {
            "label" : "Cpp Project Assembly",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++20",
                "-g", "${workspaceFolder}/src/*.cpp",
                "-I", "${workspaceFolder}/libs",
                "-o", "${workspaceFolder}/src/outcome.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}